cl_ratio  <- allele_ratio_table[grepl(cell_line,
allele_ratio_table$sample_name), ]
cl_meta   <- metadata[grepl(cell_line,
metadata$cell_line), ]
# Prepare heatmap data
heatmap_data <- prepare_heatmap_data(
cnv_called         = cl_cnv,
allele_ratio_table = cl_ratio,
chromosome_arms    = chromosome_arms,
metadata           = cl_meta
)
# Plot
p <- plot_cnv_heatmap(
heatmap_data = heatmap_data,
title        = paste0("CNV Profile — ", cell_line)
)
# Double bracket for ggplot objects in list
plot_list[[cell_line]] <- p
}
View(plot_list)
