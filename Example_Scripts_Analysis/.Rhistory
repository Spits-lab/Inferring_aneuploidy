prepare_heatmap_data <- function(cnv_called,
allele_ratio_table,
chromosome_arms,
metadata) {
# Get genome structure
genome_struct <- prepare_genome_structure(chromosome_arms)
chr_lengths   <- genome_struct$chromosome_lengths
genome_size   <- sum(chr_lengths$chr_length)
# Chr offset lookup
chr_offset <- chr_lengths %>%
mutate(
chr_num = suppressWarnings(
as.numeric(gsub("chr", "", chr))),
chr_num = case_when(
chr == "chrX" ~ 23L,
chr == "chrY" ~ 24L,
TRUE          ~ as.integer(chr_num)
)
) %>%
dplyr::select(chr, chr_num, chr_start)
# Sample order from metadata
sample_order <- metadata$sample_name
# Keep only GAIN and no_signal segments
segments_plot <- cnv_called %>%
dplyr::filter(cnv_state %in% c("gain", "no_signal")) %>%
left_join(chr_offset,
by = c("chr_name" = "chr")) %>%
mutate(
genome_start = chr_start + seg_start,
genome_end   = chr_start + seg_end
) %>%
dplyr::select(sample_name, genome_start,
genome_end, cnv_state,
seg_span, seg_n_snps,
seg_median, chr_name, arm)
# Samples with no qualifying segments
samples_with_calls  <- unique(segments_plot$sample_name)
samples_no_signal   <- setdiff(sample_order,
samples_with_calls)
cat("Samples with calls:     ",
length(samples_with_calls), "\n")
cat("Samples with no signal: ",
length(samples_no_signal), "\n")
# Build no_signal bars only if needed
# Using vector recycling safely
if (length(samples_no_signal) > 0) {
n <- length(samples_no_signal)
no_signal_bars <- data.frame(
sample_name  = samples_no_signal,
genome_start = rep(0,          n),
genome_end   = rep(genome_size, n),
cnv_state    = rep("no_signal", n),
seg_span     = rep(genome_size, n),
seg_n_snps   = rep(NA_integer_, n),
seg_median   = rep(NA_real_,    n),
chr_name     = rep(NA_character_, n),
arm          = rep(NA_character_, n),
stringsAsFactors = FALSE
)
plot_data <- bind_rows(segments_plot,
no_signal_bars)
} else {
# All samples have calls — no grey bars needed
plot_data <- segments_plot
}
# Apply sample ordering and index
plot_data <- plot_data %>%
mutate(
sample_name = factor(sample_name,
levels = sample_order),
sample_idx  = as.numeric(sample_name)
) %>%
# Drop rows where sample not in metadata
dplyr::filter(!is.na(sample_idx))
list(
plot_data    = plot_data,
chr_lengths  = chr_lengths,
genome_size  = genome_size,
sample_order = sample_order
)
}
plot_list <- list()
for(cell_line in unique(metadata$cell_line)){
cat("Processing cell line:", cell_line, "\n")
# Filter data for this cell line
cl_cnv    <- cnv_called[grepl(cell_line,
