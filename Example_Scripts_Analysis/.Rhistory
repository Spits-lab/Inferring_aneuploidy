library(DESeq2)
library(tidyr)
library(dplyr)
library(PCAtools)
count_matrix <- readRDS("C:/Users/pmgra/Documents/VUB/2026_03_Brain_Organoids_Diana/count_matrix_raw.rds")
metadata <- data.frame(info = colnames(count_matrix))
metadata <- metadata %>%
separate(
col  = info,
into = c("prefix", "cell_line", "condition", "replicate"),
sep  = "-",
remove = FALSE
) %>%
select(-prefix) %>%
mutate(
biological_sample = paste(cell_line, condition, sep = "-"),
# Extract timepoint from condition
timepoint = case_when(
grepl("cMYC",  condition) ~ "cMYC",
grepl("Day7",  condition) ~ "Day7",
grepl("Day14", condition) ~ "Day14",
grepl("Day18", condition) ~ "Day18",
grepl("Day20", condition) ~ "Day20",
grepl("Day21", condition) ~ "Day21",
TRUE ~ "unknown"
),
# Extract chromosomal context from condition
karyotype = case_when(
grepl("WT",      condition) ~ "WT",
grepl("17q",     condition) ~ "17q",
grepl("20q",     condition) ~ "20q",
grepl("1q12q24", condition) ~ "1q12q24",
grepl("12p",     condition) ~ "12p",
grepl("18q",     condition) ~ "18q",
grepl("1q",      condition) ~ "1q",
TRUE ~ "unknown"
),
karyotype_myc = case_when(
grepl("cMYC",  condition) ~ paste(karyotype, "cMYC", sep ="_"),
!grepl("cMYC",  condition) ~ karyotype
),
replicate = as.character(replicate)
)
#Creates a DESeq Object
dds    <- DESeqDataSetFromMatrix(count_matrix, metadata, ~1)
#Variation Normalization Accross all genes
#Equalises Variance Accross Expression Levels
vst    <- vst(dds, blind = TRUE)
#Extract the Matrix out of the vst function object
mat    <- assay(vst)
# ── Step 4: Select top 5000 most variable genes ─────────────────────────────
rv            <- rowVars(mat)
top_var       <- order(rv, decreasing = TRUE)[1:5000]
mat_filtered  <- mat[top_var, ]# ── Step 4: Select top 5000 most variable genes ─────────────────────────────
# ── Step 5: Run PCA ──────────────────────────────────────────────────────────
# metadata rownames must match matrix colnames
rownames(metadata) <- metadata$info
modvar <- PCAtools::pca(
mat_filtered,
metadata   = metadata,
removeVar  = 0.1      # remove bottom 10% variance genes
)
# ── Step 7: Scree plot — how many PCs matter? ────────────────────────────────
scree <- PCAtools::screeplot(
modvar,
components = PCAtools::getComponents(modvar, 1:10),
title      = "Scree plot — variance per PC"
)
p1 <- PCAtools::biplot(
modvar,
x            = "PC1",
y            = "PC2",
colby        = "cell_line",    # colour by cell line
shape        = "timepoint",    # shape by timepoint
legendPosition = "right",
title        = "PCA — PC1 vs PC2",
subtitle     = paste0(
"PC1: ", round(modvar$variance["PC1"], 1), "% variance | ",
"PC2: ", round(modvar$variance["PC2"], 1), "% variance"
),
lab          = NULL,           # no sample labels — too crowded with 156
pointSize    = 3
)
my_shapes <- c(
# WT
"WT"           = 1,    # hollow circle
"WT_cMYC"      = 16,   # filled circle
# 17q
"17q"          = 2,    # hollow triangle up
"17q_cMYC"     = 17,   # filled triangle up
# 20q
"20q"          = 0,    # hollow square
"20q_cMYC"     = 15,   # filled square
# 1q
"1q"           = 5,    # hollow diamond
"1q_cMYC"      = 18,   # filled diamond
# 12p
"12p"          = 6,    # hollow triangle down
"12p_cMYC"     = 11,
# 18q
"18q"          = 7,    # square cross
"18q_cMYC"     = 12,
# 1q12q24
"1q12q24"      = 3,    # plus
"1q12q24_cMYC" = 8     # star
)
p2 <- PCAtools::biplot(
modvar,
x              = "PC1",
y              = "PC2",
colby          = "cell_line",
shape          = "karyotype_myc",
legendPosition = "right",
shapekey        = my_shapes,
title          = "PCA",
lab            = paste(modvar$metadata$replicate,modvar$metadata$timepoint, sep ="_"),      # column name from metadata to use as label
labSize        = 2.5,              # small text so labels don't overlap
pointSize      = 3,
drawConnectors = TRUE,             # draws a line from label to point
# helps when labels overlap
widthConnectors = 0.3,
max.overlaps = 50
)
# ── Step 1: Calculate sample correlations ────────────────────────────────────
# Use the VST normalised matrix from Check 4
cor_matrix <- cor(mat_filtered, method = "pearson")
cor_summary <- purrr::map_dfr(metadata$info, function(s) {
# Get biological sample group for this sample
bio_group <- metadata$biological_sample[metadata$info == s]
# Samples in same group (excluding self)
within_group <- metadata$info[
metadata$biological_sample == bio_group &
metadata$info != s
]
# Calculate correlations
within_cor  <- if(length(within_group) > 0)
mean(cor_matrix[s, within_group])
else NA
min_cor_with_group <-  min(cor_matrix[s, within_group], na.rm = T)
min_cor_with_group <- if(min_cor_with_group == Inf) NA_integer_ else min_cor_with_group
data.frame(
sample          = s,
biological_sample = bio_group,
cell_line       = metadata$cell_line[metadata$info == s],
condition       = metadata$condition[metadata$info == s],
timepoint       = metadata$timepoint[metadata$info == s],
replicate       = metadata$replicate[metadata$info == s],
within_cor      = within_cor,
min_cor_group     = min_cor_with_group
)
})
# Flag samples where within_cor is low
low_within <- cor_summary %>%
filter(within_cor < 0.9465) %>%
arrange(within_cor)
View(cor_summary)
